# Override global gitignore (skills CLAUDE.md should be tracked)
!CLAUDE.md

# Secrets
*.env
!examples/*.example

# Runtime state
state/

# Firewall opt-in flag (managed by pearl-setup, should not be tracked per-user)
agents/*/firewall/enabled

# OS
.DS_Store

# Editor
*.swp
*.swo
*~

# Ruby tooling
.bundle/
.ruby-lsp/
