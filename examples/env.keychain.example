# Keychain auth — credentials extracted from macOS Keychain at launch
KEYCHAIN_AUTH=true

# Git identity for commits
GIT_AUTHOR_NAME=PEARL Agent
GIT_AUTHOR_EMAIL=pearl@example.com
GIT_COMMITTER_NAME=PEARL Agent
GIT_COMMITTER_EMAIL=pearl@example.com

# GitHub PAT for cloning/pushing (scoped to target repos)
GITHUB_TOKEN=github_pat_...
