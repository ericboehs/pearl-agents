# Copilot proxy auth — routes through local proxy (e.g., clapilot)
ANTHROPIC_BASE_URL=http://host.docker.internal:4141
ANTHROPIC_AUTH_TOKEN=dummy
ANTHROPIC_MODEL=claude-opus-4.6
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4.5
ANTHROPIC_SMALL_FAST_MODEL=claude-haiku-4.5
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4.5
DISABLE_NON_ESSENTIAL_MODEL_CALLS=1
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Git identity for commits
GIT_AUTHOR_NAME=PEARL Agent
GIT_AUTHOR_EMAIL=pearl@example.com
GIT_COMMITTER_NAME=PEARL Agent
GIT_COMMITTER_EMAIL=pearl@example.com

# GitHub PAT for cloning/pushing (scoped to target repos)
GITHUB_TOKEN=github_pat_...
