#!/usr/bin/env bash
set -euo pipefail

# PEARL agent setup wizard
# Creates ~/.config/pearl/agents/<agent>.env interactively

SOURCE="$0"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
BIN_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
AGENTS_REPO="${PEARL_AGENTS_REPO:-$(cd "$BIN_DIR/.." && pwd)}"
PEARL_ROOT="${PEARL_ROOT:-$HOME/.config/pearl}"
AUTH_DIR="$PEARL_ROOT/auth"

# ── Helpers ──────────────────────────────────────────────────────────

prompt() {
  local label="$1" default="${2:-}"
  if [[ -n "$default" ]]; then
    printf "  %s [%s]: " "$label" "$default" >&2
  else
    printf "  %s: " "$label" >&2
  fi
  read -r REPLY
  [[ -z "$REPLY" ]] && REPLY="$default" || true
}

prompt_secret() {
  local label="$1" default="${2:-}"
  if [[ -n "$default" ]]; then
    local masked
    masked=$(mask_token "$default")
    printf "  %s [%s]: " "$label" "$masked" >&2
  else
    printf "  %s: " "$label" >&2
  fi
  read -rs REPLY
  echo >&2
  [[ -z "$REPLY" ]] && REPLY="$default" || true
}

confirm() {
  local label="$1" default="${2:-Y}"
  if [[ "$default" == "Y" ]]; then
    printf "  %s [Y/n]: " "$label" >&2
  else
    printf "  %s [y/N]: " "$label" >&2
  fi
  read -r REPLY
  [[ -z "$REPLY" ]] && REPLY="$default" || true
  [[ "$REPLY" =~ ^[Yy] ]]
}

mask_token() {
  local token="$1"
  if [[ ${#token} -ge 12 ]]; then
    echo "${token:0:6}...${token: -6}"
  else
    echo "...${token: -4}"
  fi
}

heading() {
  echo ""
  echo "  $1"
  printf '  %*s\n' "${#1}" '' | tr ' ' '─'
}

show_pat_instructions() {
  echo "    → https://github.com/settings/personal-access-tokens/new"
  echo ""
  echo "    Recommended scopes:"
  echo "      • Contents: Read and write (clone, push)"
  echo "      • Pull requests: Read and write (open PRs)"
  echo "      • Metadata: Read-only (always required)"
}

# ── List agents ──────────────────────────────────────────────────────

# Check Docker connectivity upfront
check_docker() {
  if ! docker info &>/dev/null; then
    echo "Error: Cannot connect to Docker daemon." >&2
    echo "  Ensure Docker is running:" >&2
    echo "    macOS: open -a Docker" >&2
    echo "    Linux: sudo systemctl start docker" >&2
    exit 1
  fi
}

list_agents() {
  echo ""
  echo "Available agents:"
  echo ""
  for dockerfile in "$AGENTS_REPO"/agents/*/Dockerfile; do
    [[ -f "$dockerfile" ]] || continue
    local name
    name=$(basename "$(dirname "$dockerfile")")
    [[ "$name" == "base" ]] && continue

    local env_status image_status
    if [[ -f "$PEARL_ROOT/agents/$name.env" ]]; then
      env_status="✓ configured"
    else
      env_status="✗ not configured"
    fi
    if docker image inspect "pearl-$name:latest" &>/dev/null; then
      image_status="image ✓"
    else
      image_status="image ✗"
    fi
    printf "  %-12s %s    %s\n" "$name" "$env_status" "$image_status"
  done
  echo ""
  echo "Run 'pearl setup <agent>' to configure an agent."
}

# ── Main ─────────────────────────────────────────────────────────────

if [[ $# -eq 0 ]]; then
  check_docker
  list_agents
  exit 0
fi

AGENT="$1"
AGENT_DIR="$AGENTS_REPO/agents/$AGENT"
AGENT_ENV="$PEARL_ROOT/agents/$AGENT.env"
AGENT_STATE="$PEARL_ROOT/state/$AGENT"
IMAGE="pearl-$AGENT:latest"

# Validate agent exists
if [[ ! -f "$AGENT_DIR/Dockerfile" ]]; then
  echo "Unknown agent: $AGENT"
  list_agents
  exit 1
fi

check_docker

# Ensure an auth profile exists before proceeding
if ! compgen -G "$AUTH_DIR/*.env" > /dev/null 2>&1; then
  echo ""
  echo "  No auth profiles found. You need one before setting up an agent."
  echo ""
  if confirm "Run 'pearl auth add' now?" "Y"; then
    "$BIN_DIR/pearl-auth" add
    if ! compgen -G "$AUTH_DIR/*.env" > /dev/null 2>&1; then
      echo "  No auth profile created. Aborting."
      exit 1
    fi
  else
    echo "  Run 'pearl auth add' to create an auth profile first."
    exit 1
  fi
fi

# Check for existing config
if [[ -f "$AGENT_ENV" ]]; then
  echo ""
  echo "  Agent '$AGENT' is already configured: $AGENT_ENV"
  if ! confirm "Overwrite?" "N"; then
    exit 0
  fi
fi

echo ""
echo "══════════════════════════════════════════"
echo "  PEARL Setup — $AGENT agent"
echo "══════════════════════════════════════════"

# ── Step 1: Git Identity ────────────────────────────────────────────

heading "Step 1/4: Git Identity"
echo ""
echo "  Commits made by this agent will use this identity."
echo ""

DEFAULT_NAME=$(git config user.name 2>/dev/null || echo "")
DEFAULT_EMAIL=$(git config user.email 2>/dev/null || echo "")

prompt "Name" "$DEFAULT_NAME"
GIT_NAME="$REPLY"
if [[ -z "$GIT_NAME" ]]; then
  echo "  Error: Git name is required for agent commits."
  exit 1
fi

prompt "Email" "$DEFAULT_EMAIL"
GIT_EMAIL="$REPLY"
if [[ -z "$GIT_EMAIL" ]]; then
  echo "  Error: Git email is required for agent commits."
  exit 1
fi

# ── Step 2: GitHub Token ────────────────────────────────────────────

heading "Step 2/4: GitHub Token"
echo ""
echo "  A GitHub PAT lets the agent clone repos and open PRs."
echo ""

DETECTED_TOKEN=""
if command -v gh &>/dev/null; then
  DETECTED_TOKEN=$(gh auth token 2>/dev/null || true)
fi
[[ -z "$DETECTED_TOKEN" ]] && DETECTED_TOKEN="${GITHUB_TOKEN:-}"

GITHUB_PAT=""

if [[ -n "$DETECTED_TOKEN" ]]; then
  echo "  ✓ Found existing token ($(mask_token "$DETECTED_TOKEN"))"
  echo ""
  echo "  ⚠ This agent runs with --dangerously-skip-permissions, meaning it"
  echo "    can execute any command without asking. We strongly recommend"
  echo "    creating a dedicated fine-grained PAT scoped to only the repos"
  echo "    and permissions this agent needs:"
  echo ""
  show_pat_instructions
  echo ""
  if confirm "Use detected token?" "N"; then
    GITHUB_PAT="$DETECTED_TOKEN"
  fi
fi

if [[ -z "$GITHUB_PAT" ]]; then
  if [[ -z "$DETECTED_TOKEN" ]]; then
    echo "  Create a fine-grained PAT at:"
    show_pat_instructions
    echo ""
  fi
  prompt_secret "GitHub PAT (Enter to skip)"
  GITHUB_PAT="$REPLY"
fi

# ── Step 3: Network Firewall ──────────────────────────────────────

FIREWALL_DIR="$AGENT_DIR/firewall"
FIREWALL_ENABLED="no"

if [[ -d "$FIREWALL_DIR" ]]; then
  heading "Step 3/4: Network Firewall"
  echo ""
  echo "  This agent supports network firewall (iptables domain whitelisting)."
  echo "  When enabled, the agent can only reach whitelisted domains."
  echo ""
  if [[ -f "$FIREWALL_DIR/domains.txt" ]]; then
    echo "  Agent-specific domains:"
    while IFS= read -r line; do
      line="${line%%#*}"
      line="${line// /}"
      [[ -z "$line" ]] && continue
      echo "    • $line"
    done < "$FIREWALL_DIR/domains.txt"
    echo ""
  fi
  if confirm "Enable firewall?" "Y"; then
    touch "$FIREWALL_DIR/enabled"
    FIREWALL_ENABLED="yes"
  else
    rm -f "$FIREWALL_DIR/enabled"
    FIREWALL_ENABLED="no"
  fi
else
  heading "Step 3/4: Network Firewall"
  echo ""
  echo "  No firewall config found for this agent."
  echo "  To add one, create: agents/$AGENT/firewall/domains.txt"
  FIREWALL_ENABLED="n/a"
fi

# ── Step 4: Docker Image ────────────────────────────────────────────

heading "Step 4/4: Docker Image"
echo ""

# ── Summary ──────────────────────────────────────────────────────────

# Show active auth profile
ACTIVE_AUTH="(none)"
if [[ -f "$AUTH_DIR/active" ]]; then
  ACTIVE_AUTH=$(tr -d '[:space:]' < "$AUTH_DIR/active")
  [[ -z "$ACTIVE_AUTH" ]] && ACTIVE_AUTH="(none)"
fi

echo ""
echo "══════════════════════════════════════════"
echo "  Configuration Summary"
echo "══════════════════════════════════════════"
echo ""

printf "  %-14s %s\n" "Agent:" "$AGENT"
printf "  %-14s %s\n" "Auth profile:" "$ACTIVE_AUTH"
printf "  %-14s %s\n" "Git name:" "$GIT_NAME"
printf "  %-14s %s\n" "Git email:" "$GIT_EMAIL"
if [[ -n "$GITHUB_PAT" ]]; then
  printf "  %-14s %s\n" "GitHub PAT:" "$(mask_token "$GITHUB_PAT")"
else
  printf "  %-14s %s\n" "GitHub PAT:" "(skipped)"
fi
printf "  %-14s %s\n" "Firewall:" "$FIREWALL_ENABLED"
printf "  %-14s %s\n" "Env file:" "$AGENT_ENV"
printf "  %-14s %s\n" "State dir:" "$AGENT_STATE/"
echo ""

if ! confirm "Save this configuration?" "Y"; then
  echo "  Aborted."
  exit 0
fi

# ── Write env file (before building so config is preserved on build failure) ─

mkdir -p "$(dirname "$AGENT_ENV")" "$AGENT_STATE"

{
  echo "# Git identity for commits"
  echo "GIT_AUTHOR_NAME=$GIT_NAME"
  echo "GIT_AUTHOR_EMAIL=$GIT_EMAIL"
  echo "GIT_COMMITTER_NAME=$GIT_NAME"
  echo "GIT_COMMITTER_EMAIL=$GIT_EMAIL"

  if [[ -n "$GITHUB_PAT" ]]; then
    echo ""
    echo "# GitHub PAT for cloning/pushing"
    echo "GITHUB_TOKEN=$GITHUB_PAT"
  fi
} > "$AGENT_ENV"

chmod 600 "$AGENT_ENV"

echo ""
echo "  ✓ Created $AGENT_ENV"
echo "  ✓ Created $AGENT_STATE/"

# ── Build Docker image ──────────────────────────────────────────────

if docker image inspect "$IMAGE" &>/dev/null; then
  echo "  ✓ Image $IMAGE found"
else
  echo ""
  echo "  Building Docker images..."
  echo ""
  BASE_IMAGE="pearl-base:latest"
  if ! docker image inspect "$BASE_IMAGE" &>/dev/null; then
    echo "  Building $BASE_IMAGE..."
    if ! docker build -t "$BASE_IMAGE" "$AGENTS_REPO/agents/base/" >&2; then
      echo "  ✗ Base image build failed. Your configuration has been saved."
      echo "  Fix the build issue and run:"
      echo "    docker build -t $BASE_IMAGE $AGENTS_REPO/agents/base/"
      echo "    docker build -t $IMAGE $AGENT_DIR/"
      exit 1
    fi
  fi
  echo "  Building $IMAGE..."
  if ! docker build -t "$IMAGE" "$AGENT_DIR/" >&2; then
    echo "  ✗ Agent image build failed. Your configuration has been saved."
    echo "  Fix the build issue and run:"
    echo "    docker build -t $IMAGE $AGENT_DIR/"
    exit 1
  fi
  echo "  ✓ Images built successfully"
fi

echo ""
echo "  You're ready to go! Try:"
echo "    pearl $AGENT \"What tools do you have?\""
echo ""
