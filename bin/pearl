#!/usr/bin/env bash
set -euo pipefail

# PEARL agent runner — launches Claude Code agents in Docker containers

SOURCE="$0"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
BIN_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

usage() {
  echo "Usage: pearl <agent-name> [--auth <profile>] [claude-args...]"
  echo "       pearl setup [agent-name]"
  echo "       pearl auth [add|<profile-name>]"
  echo ""
  echo "Run a PEARL agent in a Docker container."
  echo ""
  echo "Commands:"
  echo "  setup             List agents and their config status"
  echo "  setup <agent>     Configure an agent interactively"
  echo "  auth              List auth profiles and show active"
  echo "  auth <name>       Switch active auth profile"
  echo "  auth add          Create a new auth profile interactively"
  echo ""
  echo "Options:"
  echo "  --auth <profile>  Override auth profile for this run"
  echo ""
  echo "Examples:"
  echo "  pearl code \"Implement the FizzBuzz function\""
  echo "  pearl code --resume abc123"
  echo "  pearl code -p \"Fix the failing test\""
  echo "  pearl code --auth proxy \"Use a different auth\""
  echo ""
  echo "Environment:"
  echo "  PEARL_ROOT          Config root (default: ~/.config/pearl)"
  echo "  PEARL_AGENTS_REPO   Repo checkout path (default: auto-detected)"
  exit 1
}

[[ $# -lt 1 ]] && usage

# Dispatch subcommands
case "$1" in
  setup)
    shift
    exec "$BIN_DIR/pearl-setup" "$@"
    ;;
  auth)
    shift
    exec "$BIN_DIR/pearl-auth" "$@"
    ;;
esac

AGENT="$1"
shift

# Validate agent name (alphanumeric, hyphens, underscores only)
if [[ ! "$AGENT" =~ ^[a-zA-Z0-9_-]+$ ]]; then
  echo "Error: Invalid agent name '$AGENT' (must be alphanumeric, hyphens, underscores)"
  exit 1
fi

# Parse --auth flag from remaining args
AUTH_OVERRIDE=""
REMAINING_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --auth)
      if [[ $# -lt 2 ]]; then
        echo "Error: --auth requires a profile name" >&2
        exit 1
      fi
      AUTH_OVERRIDE="$2"
      shift 2
      ;;
    *)
      REMAINING_ARGS+=("$1")
      shift
      ;;
  esac
done

PEARL_ROOT="${PEARL_ROOT:-$HOME/.config/pearl}"
AGENTS_REPO="${PEARL_AGENTS_REPO:-$(cd "$BIN_DIR/.." && pwd)}"
AGENT_ENV="$PEARL_ROOT/agents/$AGENT.env"
AGENT_STATE="$PEARL_ROOT/state/$AGENT"
SKILLS_DIR="$AGENTS_REPO/agents/$AGENT/skills"
IMAGE="pearl-$AGENT:latest"
AUTH_DIR="$PEARL_ROOT/auth"

# Check Docker connectivity upfront
if ! docker info &>/dev/null; then
  if [[ -d "/Applications/Docker.app" ]]; then
    echo "Docker not running. Starting Docker Desktop..." >&2
    open -a Docker
    printf "  Waiting for Docker to be ready..." >&2
    for _ in $(seq 1 60); do
      docker info &>/dev/null && break
      printf "." >&2
      sleep 1
    done
    echo "" >&2
    if ! docker info &>/dev/null; then
      echo "Error: Docker Desktop failed to start within 60 seconds." >&2
      echo "  Try opening Docker Desktop manually." >&2
      exit 1
    fi
  else
    echo "Error: Cannot connect to Docker daemon." >&2
    echo "  Ensure Docker is running:" >&2
    echo "    macOS:  brew install --cask docker && open -a Docker" >&2
    echo "    Linux:  sudo systemctl start docker" >&2
    exit 1
  fi
fi

# Validate agent directory exists
if [[ ! -d "$AGENTS_REPO/agents/$AGENT" ]]; then
  echo "Error: Unknown agent '$AGENT'"
  echo ""
  echo "Available agents:"
  for d in "$AGENTS_REPO"/agents/*/Dockerfile; do
    [[ -f "$d" ]] || continue
    name=$(basename "$(dirname "$d")")
    [[ "$name" == "base" ]] && continue
    echo "  $name"
  done
  exit 1
fi

# Run setup if agent env file doesn't exist
if [[ ! -f "$AGENT_ENV" ]]; then
  # If no auth profiles exist either, run auth add first
  if ! compgen -G "$AUTH_DIR/*.env" > /dev/null 2>&1; then
    echo "No auth profiles found. Let's create one first..."
    "$BIN_DIR/pearl-auth" add
    # Re-check after auth add (user may have aborted)
    if ! compgen -G "$AUTH_DIR/*.env" > /dev/null 2>&1; then
      exit 1
    fi
  fi
  echo "Agent '$AGENT' is not configured yet. Starting setup..."
  "$BIN_DIR/pearl-setup" "$AGENT"
  # Re-check after setup (user may have aborted)
  if [[ ! -f "$AGENT_ENV" ]]; then
    exit 1
  fi
fi

# Resolve auth profile: --auth flag > auth/active file > agent env (backwards compat)
AUTH_ENV=""
if [[ -n "$AUTH_OVERRIDE" ]]; then
  AUTH_ENV="$AUTH_DIR/$AUTH_OVERRIDE.env"
  if [[ ! -f "$AUTH_ENV" ]]; then
    echo "Error: Auth profile '$AUTH_OVERRIDE' not found." >&2
    echo "  Run 'pearl auth' to list available profiles." >&2
    exit 1
  fi
elif [[ -f "$AUTH_DIR/active" ]]; then
  ACTIVE_PROFILE=$(tr -d '[:space:]' < "$AUTH_DIR/active")
  if [[ -n "$ACTIVE_PROFILE" ]]; then
    AUTH_ENV="$AUTH_DIR/$ACTIVE_PROFILE.env"
    if [[ ! -f "$AUTH_ENV" ]]; then
      echo "Error: Active auth profile '$ACTIVE_PROFILE' not found." >&2
      echo "  Run 'pearl auth' to fix your configuration." >&2
      exit 1
    fi
  fi
fi

# Error if no auth profile resolved (unless agent env has auth vars for backwards compat)
if [[ -z "$AUTH_ENV" ]]; then
  if ! grep -qE "^(KEYCHAIN_AUTH|ANTHROPIC_BASE_URL|ANTHROPIC_API_KEY)=" "$AGENT_ENV" 2>/dev/null; then
    echo "Error: No active auth profile. Run 'pearl auth add' to create one." >&2
    exit 1
  fi
fi

# Backwards compat warning: detect auth vars in agent env
if [[ -n "$AUTH_ENV" ]]; then
  if grep -qE "^(KEYCHAIN_AUTH|ANTHROPIC_BASE_URL|ANTHROPIC_API_KEY|ANTHROPIC_AUTH_TOKEN)=" "$AGENT_ENV" 2>/dev/null; then
    echo "Warning: Agent env '$AGENT_ENV' contains auth variables." >&2
    echo "  These are now managed by auth profiles. The auth profile will take precedence." >&2
    echo "  Consider removing auth variables from the agent env and using 'pearl auth' instead." >&2
    echo "" >&2
  fi
fi

# Persistent state dir for Claude settings
mkdir -p "$AGENT_STATE"

# Seed .claude.json from host if not yet initialized
if [[ ! -f "$AGENT_STATE/.claude.json" && -f "$HOME/.claude.json" ]]; then
  cp "$HOME/.claude.json" "$AGENT_STATE/.claude.json"
fi

# Sync select settings from host (statusLine, syntax highlighting, thinking mode)
if [[ -f "$HOME/.claude/settings.json" ]] && command -v jq &>/dev/null; then
  HOST_SETTINGS="$HOME/.claude/settings.json"
  AGENT_SETTINGS="$AGENT_STATE/settings.json"
  # Rewrite localhost:4141 → host.docker.internal:4141 in statusLine for Docker
  PICKED=$(jq '{statusLine, syntaxHighlightingDisabled, alwaysThinkingEnabled}
    | if .statusLine.command then .statusLine.command |= gsub("localhost:4141"; "host.docker.internal:4141") else . end' \
    "$HOST_SETTINGS" 2>/dev/null) && {
    if [[ -f "$AGENT_SETTINGS" ]]; then
      # Merge picked keys into existing agent settings
      jq -s '.[0] * .[1]' "$AGENT_SETTINGS" <(echo "$PICKED") > "$AGENT_SETTINGS.tmp" && \
        mv "$AGENT_SETTINGS.tmp" "$AGENT_SETTINGS" || rm -f "$AGENT_SETTINGS.tmp"
    else
      echo "$PICKED" > "$AGENT_SETTINGS"
    fi
  }
fi

# Ensure installMethod is npm (container uses npm, not native)
if [[ -f "$AGENT_STATE/.claude.json" ]]; then
  if command -v jq &>/dev/null; then
    jq '.installMethod = "npm"' "$AGENT_STATE/.claude.json" > "$AGENT_STATE/.claude.json.tmp" && \
      mv "$AGENT_STATE/.claude.json.tmp" "$AGENT_STATE/.claude.json" || {
        echo "Warning: Could not update installMethod in .claude.json" >&2
        rm -f "$AGENT_STATE/.claude.json.tmp"
      }
  else
    echo "Warning: jq not found. Skipping installMethod fix for .claude.json." >&2
    echo "  Install jq to suppress the Claude npm-to-native warning." >&2
  fi
fi

# Keychain auth: extract credentials from macOS Keychain
# When an auth profile is active, only check the auth profile (not agent env).
# Fall back to agent env only when no auth profile exists (backwards compat).
KEYCHAIN_SOURCE=""
if [[ -n "$AUTH_ENV" ]]; then
  grep -q "KEYCHAIN_AUTH=true" "$AUTH_ENV" 2>/dev/null && KEYCHAIN_SOURCE="$AUTH_ENV"
elif grep -q "KEYCHAIN_AUTH=true" "$AGENT_ENV" 2>/dev/null; then
  KEYCHAIN_SOURCE="$AGENT_ENV"
fi

if [[ -n "$KEYCHAIN_SOURCE" ]]; then
  CREDS=$(security find-generic-password -s "Claude Code-credentials" -a "$USER" -w 2>/dev/null) || {
    echo "Error: No Claude credentials found in macOS Keychain."
    echo "  Run 'claude login' on your host first, then try again."
    echo "  If your keychain is locked, unlock it with: security unlock-keychain"
    exit 1
  }
  echo "$CREDS" > "$AGENT_STATE/.credentials.json"
  chmod 600 "$AGENT_STATE/.credentials.json"
else
  # Remove stale credentials from previous keychain runs
  rm -f "$AGENT_STATE/.credentials.json"
fi

# Build docker args — agent env first, auth env second (auth wins on duplicates)
DOCKER_ARGS=(-it --rm --env-file "$AGENT_ENV")
[[ -n "$AUTH_ENV" ]] && DOCKER_ARGS+=(--env-file "$AUTH_ENV")

# Mount persistent Claude state
DOCKER_ARGS+=(-v "$AGENT_STATE:/home/agent/.claude")
[[ -f "$AGENT_STATE/.claude.json" ]] && \
  DOCKER_ARGS+=(-v "$AGENT_STATE/.claude.json:/home/agent/.claude.json")

# Mount skills (volume-mounted, not baked into image)
[[ -d "$SKILLS_DIR" ]] && DOCKER_ARGS+=(-v "$SKILLS_DIR:/skills:ro")

# Mount tools (MCP configs, custom scripts)
TOOLS_DIR="$AGENTS_REPO/agents/$AGENT/tools"
[[ -d "$TOOLS_DIR" ]] && DOCKER_ARGS+=(-v "$TOOLS_DIR:/tools:ro")

# Mount inbound images (set by EARL's pearl_handler)
[[ -n "${PEARL_IMAGES:-}" && -d "$PEARL_IMAGES" ]] && \
  DOCKER_ARGS+=(-v "$PEARL_IMAGES:/pearl-images:ro")

# Mount output directory (set by EARL's pearl_handler)
[[ -n "${PEARL_OUTPUT:-}" ]] && \
  DOCKER_ARGS+=(-v "$PEARL_OUTPUT:/pearl-output")

# Firewall support (enabled by default, opt out with firewall/disabled)
FIREWALL_DIR="$AGENTS_REPO/agents/$AGENT/firewall"
if [[ ! -f "$FIREWALL_DIR/disabled" ]]; then
  DOCKER_ARGS+=(--cap-add=NET_ADMIN --cap-add=NET_RAW)
  [[ -d "$FIREWALL_DIR" ]] && DOCKER_ARGS+=(-v "$FIREWALL_DIR:/firewall:ro")
fi

# Mount current directory as workspace
DOCKER_ARGS+=(-v "$(pwd):/workspace" -w /workspace)

# Copilot proxy needs host.docker.internal — check both auth and agent env
if { [[ -n "$AUTH_ENV" ]] && grep -q "ANTHROPIC_BASE_URL" "$AUTH_ENV" 2>/dev/null; } || \
   grep -q "ANTHROPIC_BASE_URL" "$AGENT_ENV" 2>/dev/null; then
  DOCKER_ARGS+=(--add-host=host.docker.internal:host-gateway)
fi

# Verify image exists before launching
if ! docker image inspect "$IMAGE" &>/dev/null; then
  echo "Error: Docker image '$IMAGE' not found."
  echo "  Run:  pearl setup $AGENT"
  exit 1
fi

exec docker run "${DOCKER_ARGS[@]}" "$IMAGE" \
  claude --dangerously-skip-permissions ${REMAINING_ARGS[@]+"${REMAINING_ARGS[@]}"}
